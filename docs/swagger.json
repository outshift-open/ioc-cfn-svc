                        "name": "workspaceId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Multi-Agentic System ID",
                        "name": "masId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Query request",
