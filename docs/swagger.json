    },
    "basePath": "/",
    "paths": {
        "/api/workspaces/{workspaceId}/multi-agentic-systems/{masId}/agents/{agentId}/memory-operations": {
            "post": {
                "description": "Forwards REST API requests to a remote memory provider (Mem0, Graphiti, etc.) for agent-specific memory operations.\nThe memory provider base URL and auth credentials are auto-resolved from management plane config based on workspace/MAS/agent IDs.\nThe `http-url` field should contain the relative path and query parameters to append to the provider base URL.\n\n**GET example** — retrieve memories:\n```json\n{\n\"header\": {},\n\"payload\": {\n\"http-request-type\": \"GET\",\n\"http-url\": \"v1/memories/?user_id=curl-test-user\",\n\"http-request-body\": {},\n\"http-headers\": {}\n}\n}\n```\n\n**POST example** — add memories:\n```json\n{\n\"header\": {},\n\"payload\": {\n\"http-request-type\": \"POST\",\n\"http-url\": \"/v1/memories/\",\n\"http-request-body\": {\n\"messages\": [{\"role\": \"user\", \"content\": \"I prefer dark mode in all my apps\"}],\n\"user_id\": \"curl-test-user\"\n},\n\"http-headers\": {}\n}\n}\n```",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "memory-operations"
                ],
                "summary": "Proxy API requests to a remote memory provider",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Workspace ID",
                        "name": "workspaceId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Multi-Agentic System ID",
                        "name": "masId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Agent ID",
                        "name": "agentId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Memory operation request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/memoryoperations.MemoryOperationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Proxied response (actual provider status is in http-status field)",
                        "schema": {
                            "$ref": "#/definitions/memoryoperations.MemoryOperationResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request body or missing http-request-type",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Memory provider config not found for agent",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "502": {
                        "description": "Failed to forward request to memory provider",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Memory proxy client not configured",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/workspaces/{workspaceId}/multi-agentic-systems/{masId}/shared-memories": {
            "post": {
                "description": "Creates or updates shared memories with entries (concepts and relations) extracted from the provided trace or OpenClaw output for a given workspace and multi-agentic system.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "shared-memories"
                ],
                "summary": "Create or update shared memories.",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Workspace ID",
                        "name": "workspaceId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Multi-Agentic System ID",
                        "name": "masId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Create or update shared memories request",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/sharedmemory.CreateOrUpdateRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Shared memories successfully created or updated",
                        "schema": {
                            "$ref": "#/definitions/sharedmemory.CreateOrUpdateResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/workspaces/{workspaceId}/multi-agentic-systems/{masId}/shared-memories/query": {
            "post": {
                "description": "Queries shared memories for a given workspace and multi-agentic system using a graph path query.",
                "consumes": [
