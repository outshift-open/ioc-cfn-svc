# IoC CFN Service Environment Variables
# Copy this file to .env and fill in your values

# Management Plane Configuration
# Get these from IoC Management Plane UI:
# - WORKSPACE_ID: Use a default workspace and copy its ID
# - X_API_KEY: Create an API key manually and copy it
WORKSPACE_ID=your-workspace-id-here
X_API_KEY=your-api-key-here

MGMT_URL=http://host.docker.internal:8000
# CFN_NAME=cfn-local
# HEARTBEAT_INTERVAL_SECONDS=29
