# IoC CFN Service Environment Variables
# Copy this file to .env and fill in your values

# Management Plane Configuration
MGMT_URL=http://localhost:9000 (http://<MGMT_URL>:9000, http://host.docker.internal:9000, http://ioc-cfn-mgmt-plane-svc:9000 for docker-full-stack)
KNOWLEDGE_MEMORY_SVC_URL=http://localhost:9003 (http://ioc-knowledge-memory-svc:9003 for docker-full-stack)

# CFN Configuration
# For local testing, use "My Cognition Fabric Node" so that MAS associates with this CFN
CFN_NAME=My Cognition Fabric Node
HEARTBEAT_INTERVAL_SECONDS=10
SERVICE_NAME=ioc-cfn-svc
LOG_LEVEL=INFO
DISABLE_VALIDATION=false

# LLM / Cognition Engine Configuration
LLM_PROVIDER=azure-openai
COGNITION_ENGINE_SVC_URL=http://localhost:9004 (http://ioc-cfn-cognition-engine:9004 for docker-full-stack)

# Timeout configuration
# Request flow: Client → cfn-svc → gateway(:9004) → LLM
#                               ↓
#                        memory-svc(:9003)
#
# COGNITION_AGENTS_TIMEOUT_SECONDS: how long cfn-svc waits for gateway to return a /decide result.
#   Increase for long negotiations with retries. Must be < SERVER_TIMEOUT_SECONDS.
# SERVER_TIMEOUT_SECONDS: max lifetime of an inbound request to cfn-svc (read/write timeout).
#   Must be > COGNITION_AGENTS_TIMEOUT_SECONDS, otherwise the server closes the connection
#   before the gateway finishes.
# MEMORY_CLIENT_TIMEOUT_SECONDS: how long cfn-svc waits when reading/writing shared memory.
COGNITION_AGENTS_TIMEOUT_SECONDS=120   # default 120; set to 600 locally for long negotiations with retries
SERVER_TIMEOUT_SECONDS=120             # default 120; must be > COGNITION_AGENTS_TIMEOUT_SECONDS; set to 600 locally
MEMORY_CLIENT_TIMEOUT_SECONDS=30       # default 30; set to 300 locally if shared memory writes are slow

# Pagination Configuration (optional — default values are used if not set)
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# PostgreSQL Database Configuration
DB_HOST=localhost (localhost, host.docker.internal, ioc-knowledge-db for docker-full-stack)
DB_PORT=5456 (5456 for local since DB is mapped to host port 5456, 5432 for docker-full-stack)
DB_NAME=cfn_cp
DB_USER=postgresUser
DB_PASSWORD=postgresPW
DB_SSL_MODE=disable (disable, require)

# TimescaleDB is always enabled for time-series metrics storage
# Requires PostgreSQL with TimescaleDB extension installed
